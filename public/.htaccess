<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let API requests pass through to Node.js - do NOT rewrite
  RewriteRule ^api/ - [L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
